            "message": "Items obtenidos exitosamente",
            "metadata": {},
            "success": true
          },
          "contentType": "application/json",
          "encoded": false
        },
        "headers": {
          "Content-Type": [
            "application/json"
          ]
        },
        "matchingRules": {
          "body": {
            "$.data.items": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
