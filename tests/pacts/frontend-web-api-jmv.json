{
  "consumer": {
    "name": "frontend-web"
  },
  "interactions": [
    {
      "description": "una solicitud para listar items",
      "pending": false,
      "providerStates": [
        {
          "name": "existen items activos"
        }
      ],
      "request": {
        "method": "GET",
        "path": "/api/v1/items/"
      },
      "response": {
        "body": {
          "content": {
            "data": {
              "items": [
                {
                  "categoria_id": null,
                  "codigo_sku": "AB-1001",
                  "description": "Caja para ecommerce",
