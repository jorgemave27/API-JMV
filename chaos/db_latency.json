{
  "version": "1.0.0",
  "title": "DB Latency",
  "description": "Agregar latencia artificial a Postgres",
  "steady-state-hypothesis": {
    "title": "API responde",
    "probes": [
      {
        "name": "health-check",
        "type": "probe",
        "provider": {
          "type": "http",
          "url": "http://localhost:8000/health"
        }
      }
    ]
  },
  "method": [
    {
      "name": "add-latency",
      "type": "action",
      "provider": {
        "type": "process",
        "path": "docker",
        "arguments": "exec postgres tc qdisc add dev eth0 root netem delay 2000ms"
      }
    },
    {
      "name": "wait",
      "type": "action",
      "provider": {
        "type": "process",
        "path": "sleep",
        "arguments": "30"
      }
    },
    {
      "name": "remove-latency",
      "type": "action",
      "provider": {
        "type": "process",
        "path": "docker",
        "arguments": "exec postgres tc qdisc del dev eth0 root"
      }
    }
  ]
}
